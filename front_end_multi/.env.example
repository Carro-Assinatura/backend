# ============================================================
# Supabase - Banco de dados e autenticação
# ============================================================
# 1. Acesse https://supabase.com e crie um projeto
# 2. No dashboard, vá em Settings > API
# 3. Copie a "Project URL" e a "anon public" key:
VITE_SUPABASE_URL=SUA_URL_DO_SUPABASE
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_AQUI

# ============================================================
# Google Sheets - Configuração
# ============================================================
# 1. Acesse https://console.cloud.google.com
# 2. Crie um projeto (ou use um existente)
# 3. Ative a API "Google Sheets API"
# 4. Em "Credenciais", crie uma "Chave de API"
# 5. Cole a chave abaixo:
VITE_GOOGLE_SHEETS_API_KEY=SUA_CHAVE_DE_API_AQUI

# ID da planilha Google Sheets
# O ID fica na URL da planilha:
# https://docs.google.com/spreadsheets/d/ESSE_AQUI_É_O_ID/edit
VITE_GOOGLE_SHEETS_ID=SEU_ID_DA_PLANILHA_AQUI

# Nome da aba da planilha (ex: "Página1", "Carros", "Sheet1")
VITE_GOOGLE_SHEETS_TAB=Página1

# ============================================================
# Mapeamento de colunas da planilha
# ============================================================
# Informe o nome EXATO da coluna (cabeçalho) na sua planilha
# para cada campo abaixo:

# Coluna com o nome do carro (ex: "Carro", "Modelo", "Veículo")
VITE_COLUMN_CAR_NAME=Carro

# Coluna com a categoria (ex: "Categoria", "Tipo", "Segmento")
VITE_COLUMN_CATEGORY=Categoria

# Coluna com o preço mensal (ex: "Preço", "Valor", "Mensalidade")
VITE_COLUMN_PRICE=Preço

# Coluna com a URL da imagem (ex: "Imagem", "Foto", "URL Imagem")
VITE_COLUMN_IMAGE=Imagem

# ============================================================
# Busca automática de imagens + Remoção de fundo
# ============================================================
# As imagens dos carros são buscadas automaticamente pela Wikipedia.
#
# Para remover o fundo automaticamente (fundo transparente):
# 1. Acesse https://www.remove.bg/api e crie uma conta gratuita
# 2. Na dashboard, copie sua "API Key"
# 3. Cole abaixo:
VITE_REMOVEBG_API_KEY=SUA_CHAVE_REMOVEBG_AQUI
